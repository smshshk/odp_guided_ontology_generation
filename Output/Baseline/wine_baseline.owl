  <rdf:Description rdf:about="http://example.org/wine-cq-ontology#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label>Wine Competency Question Ontology</rdfs:label>
    <dcterms:description>An OWL ontology synthesised from wine-related competency questions concerning wine characteristics, colour classification, food pairing, dish appropriateness, vintage-dependent qualities, and good vintages.</dcterms:description>
