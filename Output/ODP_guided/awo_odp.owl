  <rdf:Description rdf:about="http://example.org/awo-odp-synthesis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dcterms:title>AWO competency-question ontology synthesised with selected ODPs</dcterms:title>
    <dcterms:description>Synthesised ontology from animal-world competency questions and the inspected ODP library. Selected ODP commitments include SpeciesEat, PartOf, Place, SpeciesHabitat, and SpeciesConservation where conceptually required.</dcterms:description>
